# Test environment configuration
NODE_ENV=test
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Test database
DATABASE_URL=postgresql://test:test@localhost:5432/startupspark_test

# Test authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=test_secret
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpassword

# Test Stripe configuration
STRIPE_SECRET_KEY=sk_test_mock
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_mock
STRIPE_WEBHOOK_SECRET=whsec_test
STRIPE_BASIC_PRICE_ID=price_test_basic
STRIPE_PRO_PRICE_ID=price_test_pro
STRIPE_ENTERPRISE_PRICE_ID=price_test_enterprise

# Test OpenAI configuration
OPENAI_API_KEY=sk-test
OPENAI_ORG_ID=org-test

# Test Redis configuration
REDIS_URL=redis://localhost:6379/1

# Test feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_MONITORING=false

# Test rate limits
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# Test timeouts
TEST_TIMEOUT=30000
TEST_RETRY_COUNT=2

# Test data configuration
TEST_DATA_CLEANUP=true
TEST_AUTO_CLEANUP_TIMEOUT=5000

# Browser testing configuration
BROWSER_HEADLESS=true
BROWSER_SLOWMO=0
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720

# Test monitoring
SENTRY_DSN=
LOGFLARE_API_KEY=
LOGFLARE_SOURCE_ID=

# Test notifications
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# CI specific settings
CI_PARALLEL_TESTS=2
CI_TEST_SHARD=1
CI_TOTAL_SHARDS=1

# Debug settings
DEBUG_TESTS=false
VERBOSE_LOGS=false
SAVE_FAILED_TEST_ARTIFACTS=true
