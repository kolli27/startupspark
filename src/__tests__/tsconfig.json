{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "types": ["node", "jest", "@playwright/test"],
    "isolatedModules": false,
    "esModuleInterop": true,
    "target": "es2019",
    "lib": ["dom", "dom.iterable", "esnext"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
